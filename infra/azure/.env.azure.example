NODE_ENV=production
HEALTH_PORT=3000
HEADLESS=true

# Persistencia: sem volume montado, use /app/...; com Azure Files em /mnt/persist, use os caminhos abaixo.
AUTH_PATH=/app/.wwebjs_auth
DATA_DIR=/app/data
# AUTH_PATH=/mnt/persist/.wwebjs_auth
# DATA_DIR=/mnt/persist/data

# Segredos (definir via Key Vault)
GROQ_API_KEY=
ADMIN_NUMBER=
