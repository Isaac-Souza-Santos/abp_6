{
  "name": "procon-jacarei-whatsapp-bot",
  "version": "1.0.0",
  "description": "Chat bot WhatsApp para Procon Jacareí/SP - atendimento e orientação ao consumidor",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "panel:dev": "npm --prefix painel-interno run dev",
    "panel:build": "npm --prefix painel-interno run build",
    "panel:preview": "npm --prefix painel-interno run preview",
    "panel:package:appservice": "powershell -NoProfile -ExecutionPolicy Bypass -File infra/azure/package-painel-app-service.ps1",
    "panel:deploy:appservice": "powershell -NoProfile -ExecutionPolicy Bypass -File infra/azure/deploy-painel-app-service.ps1",
    "lint": "eslint src --ext .ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "keywords": [
    "whatsapp",
    "bot",
    "procon",
    "jacarei",
    "consumidor"
  ],
  "author": "Procon Jacareí SP",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "dotenv": "^16.3.1",
    "firebase-admin": "^13.7.0",
    "groq-sdk": "^0.5.0",
    "jose": "^6.2.2",
    "qrcode-terminal": "^0.12.0",
    "whatsapp-web.js": "^1.23.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.10.0",
    "@types/qrcode-terminal": "^0.12.2",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.55.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node"
  }
}
