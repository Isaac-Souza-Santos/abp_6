# Opcional: use .env para configurar variáveis no futuro
# NODE_ENV=production

# Número do WhatsApp do atendente (com DDI, sem espaços). Quem usar esse número pode enviar "atendente" ou "historico" ou "metricas" para ver histórico de agendamentos e métricas.
# Número do projeto: +55 12 99207-4513
# ADMIN_NUMBER=5512992074513

# Outlook (Microsoft Graph) – API gratuita para criar eventos no calendário ao confirmar agendamento. Ver docs/OUTLOOK-AGENDAMENTO.md.
# OUTLOOK_CLIENT_ID=
# OUTLOOK_CLIENT_SECRET=
# OUTLOOK_REFRESH_TOKEN=
# OUTLOOK_TENANT_ID=common
# OUTLOOK_TIMEZONE=E. South America Standard Time
